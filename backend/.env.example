LLM_PROVIDER=openai_compatible
LLM_API_KEY=your_api_key_here
# For ModelScope: use a model listed at https://api-inference.modelscope.cn/v1/models
# Recommended: deepseek-ai/DeepSeek-V3.2 or moonshotai/Kimi-K2.5
LLM_MODEL=deepseek-ai/DeepSeek-V3.2
# ModelScope: https://api-inference.modelscope.cn/v1/
# DashScope:   https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_BASE_URL=https://api-inference.modelscope.cn/v1/
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=1

# Auth / JWT
# Replace this with a long random value in backend/.env. Do not commit real secrets.
JWT_SECRET_KEY=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# RAG / Chroma
CHROMA_DB_DIR=db/chroma_db
CHROMA_COLLECTION_NAME=travel_guides
EMBEDDING_MODEL=text-embedding-v4
RERANK_MODEL=qwen3-rerank
EMBEDDING_BATCH_SIZE=10

# Redis / Cache
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_KEY_PREFIX=trip_planner
REDIS_DEFAULT_TTL_SECONDS=1800
REDIS_WEATHER_TTL_SECONDS=1800
REDIS_MAP_TTL_SECONDS=86400
REDIS_RAG_TTL_SECONDS=21600
REDIS_RERANK_TTL_SECONDS=21600

# Amap / Gaode Map
AMAP_API_KEY=your_amap_api_key
AMAP_BASE_URL=https://restapi.amap.com/v3
AMAP_DEFAULT_CITY=
AMAP_TIMEOUT_SECONDS=20
ENABLE_AMAP_ENRICHMENT=true

# Tavily external search
# Optional. Leave empty to disable Tavily and fall back to Amap, local RAG or demo data.
TAVILY_API_KEY=
TAVILY_API_URL=https://api.tavily.com/search
TAVILY_TIMEOUT_SECONDS=20
TAVILY_MAX_RETRIES=1

# Browser visible price observation
# Disabled by default. When enabled, the backend opens submitted URLs with Playwright,
# reads visible page text, and extracts prices without login bypass, booking, or payment.
BROWSER_ENABLED=false
BROWSER_HEADLESS=true
BROWSER_TIMEOUT_SECONDS=30
BROWSER_ALLOWED_DOMAINS=*
BROWSER_MAX_URLS=4
BROWSER_MAX_PRICE_ITEMS=8
BROWSER_REQUIRE_HUMAN_ON_LOGIN=true
BROWSER_REQUIRE_HUMAN_ON_CAPTCHA=true
BROWSER_HUMAN_WAIT_SECONDS=60
# Connect to already-running Chrome via CDP (takes priority over launching new browser).
# Example: http://localhost:9222 (start Chrome with: chrome --remote-debugging-port=9222)
BROWSER_CDP_URL=
# Persistent Chrome user data directory. When CDP is not used, the browser
# launches with a persistent profile, preserving cookies/sessions across runs.
# Example (Windows): C:/Users/<name>/AppData/Local/Google/Chrome/User Data
# Leave empty to use a fresh temporary profile each time.
BROWSER_USER_DATA_DIR=
# Browser channel. Set to "msedge" to use system Microsoft Edge instead of
# bundled Chromium. Leave empty for default (bundled Chromium).
BROWSER_CHANNEL=
